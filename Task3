<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Responsive Landing Page</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: Arial, sans-serif;
    }

    body{
      background:#f5f5f5;
      color:#333;
    }

    /* Navbar */
    nav{
      width:100%;
      padding:15px 8%;
      background:#111827;
      display:flex;
      justify-content:space-between;
      align-items:center;
      position:fixed;
      top:0;
      left:0;
      z-index:1000;
    }

    nav h1{
      color:white;
      font-size:28px;
    }

    nav ul{
      display:flex;
      list-style:none;
      gap:25px;
    }

    nav ul li a{
      text-decoration:none;
      color:white;
      font-size:16px;
      transition:0.3s;
    }

    nav ul li a:hover{
      color:#38bdf8;
    }

    /* Hero Section */
    .hero{
      min-height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      padding:120px 8% 50px;
      gap:50px;
      flex-wrap:wrap;
      background:linear-gradient(to right,#0f172a,#1e293b);
      color:white;
    }

    .hero-text{
      flex:1;
      min-width:280px;
    }

    .hero-text h2{
      font-size:52px;
      margin-bottom:20px;
    }

    .hero-text p{
      font-size:18px;
      line-height:1.6;
      margin-bottom:25px;
    }

    .hero-text button{
      padding:14px 30px;
      border:none;
      background:#38bdf8;
      color:white;
      font-size:16px;
      border-radius:8px;
      cursor:pointer;
      transition:0.3s;
    }

    .hero-text button:hover{
      background:#0ea5e9;
    }

    .hero-image{
      flex:1;
      min-width:280px;
      text-align:center;
    }

    .hero-image img{
      width:100%;
      max-width:500px;
      border-radius:15px;
    }

    /* Features */
    .features{
      padding:80px 8%;
      background:white;
      text-align:center;
    }

    .features h2{
      font-size:40px;
      margin-bottom:50px;
    }

    .feature-box{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
      gap:30px;
    }

    .card{
      background:#f1f5f9;
      padding:30px;
      border-radius:15px;
      transition:0.3s;
    }

    .card:hover{
      transform:translateY(-8px);
    }

    .card h3{
      margin-bottom:15px;
      color:#0f172a;
    }

    /* Footer */
    footer{
      background:#111827;
      color:white;
      text-align:center;
      padding:20px;
    }

    /* Responsive */
    @media(max-width:768px){

      nav{
        flex-direction:column;
        gap:15px;
      }

      .hero-text h2{
        font-size:38px;
      }

      nav ul{
        gap:15px;
      }
    }
  </style>
</head>

<body>

  <!-- Navbar -->
  <nav>
    <h1>Brand</h1>

    <ul>
      <li><a href="#">Home</a></li>
      <li><a href="#">Features</a></li>
      <li><a href="#">About</a></li>
      <li><a href="#">Contact</a></li>
    </ul>
  </nav>

  <!-- Hero Section -->
  <section class="hero">

    <div class="hero-text">
      <h2>Create Your Dream Website</h2>

      <p>
        Modern responsive landing page using HTML and CSS.
        Works perfectly on desktop, tablet and mobile devices.
      </p>

      <button>Get Started</button>
    </div>

    <div class="hero-image">
      <img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085"
      alt="Laptop Image">
    </div>

  </section>

  <!-- Features -->
  <section class="features">

    <h2>Our Features</h2>

    <div class="feature-box">

      <div class="card">
        <h3>Responsive Design</h3>
        <p>Looks perfect on all screen sizes.</p>
      </div>

      <div class="card">
        <h3>Fast Performance</h3>
        <p>Optimized for speed and smooth experience.</p>
      </div>

      <div class="card">
        <h3>Modern UI</h3>
        <p>Clean and attractive user interface.</p>
      </div>

    </div>

  </section>

  <!-- Footer -->
  <footer>
    <p>© 2026 Responsive Landing Page | All Rights Reserved</p>
  </footer>

</body>
</html>
